# Copy to `.env` for local use only. Replace placeholders locally; never commit secrets.

# =================================================
# REQUIRED TODAY
# Core local development infrastructure and API configuration
# =================================================

# Postgres Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kogniq
POSTGRES_USER=kogniq_user
POSTGRES_PASSWORD=kogniq_dev_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# pgAdmin Configuration
PGADMIN_EMAIL=admin@kogniq.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Core Application Settings
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=dev_secret_key_change_in_production
JWT_SECRET=dev_jwt_secret_change_in_production

# Kogniq API Foundation
KOGNIQ_API_APP_NAME="Kogniq API"
KOGNIQ_API_API_VERSION="v1"
KOGNIQ_API_ENVIRONMENT="development"
KOGNIQ_API_BUILD="local"
KOGNIQ_API_COMMIT="unknown"
KOGNIQ_API_LOG_LEVEL="info"
KOGNIQ_API_CORS_ORIGINS=["http://localhost:3000"]
KOGNIQ_API_CORS_ALLOW_CREDENTIALS=true
KOGNIQ_API_ALLOWED_HOSTS=["localhost", "127.0.0.1"]
KOGNIQ_API_GZIP_ENABLED=true
KOGNIQ_API_GZIP_MINIMUM_SIZE=500
KOGNIQ_API_REQUEST_ID_HEADER="X-Request-ID"
KOGNIQ_API_PROCESS_TIME_HEADER="X-Process-Time-Ms"
KOGNIQ_API_OPENAPI_SERVERS=[{"url":"/","description":"Local environment"}]
KOGNIQ_API_CONTACT_EMAIL="contact@kogniq.local"
KOGNIQ_API_LICENSE_NAME="MIT"
KOGNIQ_API_LICENSE_URL="https://opensource.org/licenses/MIT"

# =================================================
# REQUIRED LATER (Stage 5)
# Vector storage for RAG capabilities
# =================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333

# =================================================
# REQUIRED LATER (Stage 6)
# Graph storage for Knowledge Graph capabilities
# =================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password

# =================================================
# REQUIRED LATER (Stage 8)
# AI Providers and External Integrations
# =================================================

OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
HF_TOKEN=<YOUR_HF_TOKEN>

# Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
