# Copy to `.env` for local use only. Replace placeholders locally; never commit secrets.

# =================================================
# [CURRENT] Database Persistence
# =================================================

# POSTGRES_HOST
# What: Hostname for the PostgreSQL database.
# Required: Yes
# Optional: No
# Example: localhost
POSTGRES_HOST=localhost

# POSTGRES_PORT
# What: Port for the PostgreSQL database.
# Required: Yes
# Optional: No
# Example: 5432
POSTGRES_PORT=5432

# POSTGRES_DB
# What: Name of the PostgreSQL database to connect to.
# Required: Yes
# Optional: No
# Example: kogniq
POSTGRES_DB=kogniq

# POSTGRES_USER
# What: Username for the PostgreSQL database.
# Required: Yes
# Optional: No
# Example: kogniq_user
POSTGRES_USER=kogniq_user

# POSTGRES_PASSWORD
# What: Password for the PostgreSQL database. Replace this in production.
# Required: Yes
# Optional: No
# Example: kogniq_dev_password
POSTGRES_PASSWORD=kogniq_dev_password

# SQLALCHEMY_ECHO
# What: Whether to echo SQL statements to the console.
# Required: No
# Optional: Yes
# Example: false
SQLALCHEMY_ECHO=false

# DATABASE_POOL_SIZE
# What: Number of connections to keep open in the connection pool.
# Required: No
# Optional: Yes
# Example: 5
DATABASE_POOL_SIZE=5

# DATABASE_MAX_OVERFLOW
# What: Number of connections to allow beyond the pool size.
# Required: No
# Optional: Yes
# Example: 10
DATABASE_MAX_OVERFLOW=10

# PGADMIN_EMAIL
# What: Default email for the pgAdmin web UI.
# Required: No (Only if running the pgAdmin docker container)
# Optional: Yes
# Example: admin@kogniq.com
PGADMIN_EMAIL=admin@kogniq.com

# PGADMIN_PASSWORD
# What: Default password for the pgAdmin web UI.
# Required: No (Only if running the pgAdmin docker container)
# Optional: Yes
# Example: admin
PGADMIN_PASSWORD=admin

# PGADMIN_PORT
# What: Port for the pgAdmin web UI.
# Required: No (Only if running the pgAdmin docker container)
# Optional: Yes
# Example: 5050
PGADMIN_PORT=5050

# =================================================
# [CURRENT] API Configuration
# =================================================

# KOGNIQ_API_ENVIRONMENT
# What: Target runtime environment (development, staging, production).
# Required: No
# Optional: Yes
# Example: development
KOGNIQ_API_ENVIRONMENT="development"

# KOGNIQ_API_LOG_LEVEL
# What: Minimum log severity level to capture.
# Required: No
# Optional: Yes
# Example: info
KOGNIQ_API_LOG_LEVEL="info"

# KOGNIQ_API_CORS_ORIGINS
# What: JSON array of allowed origins for Cross-Origin Resource Sharing.
# Required: No
# Optional: Yes
# Example: '["http://localhost:3000"]'
KOGNIQ_API_CORS_ORIGINS=["http://localhost:3000"]

# KOGNIQ_API_ALLOWED_HOSTS
# What: JSON array of allowed host headers.
# Required: No
# Optional: Yes
# Example: '["localhost", "127.0.0.1"]'
KOGNIQ_API_ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# =================================================
# [FUTURE] Caching (Redis)
# =================================================

# REDIS_HOST
# What: Hostname for the Redis cache server.
# Required: No (Future Stage)
# Optional: Yes
# Example: localhost
REDIS_HOST=localhost

# REDIS_PORT
# What: Port for the Redis cache server.
# Required: No (Future Stage)
# Optional: Yes
# Example: 6379
REDIS_PORT=6379

# =================================================
# [FUTURE] Security & Identity
# =================================================

# SECRET_KEY
# What: Main secret key for application-level cryptography.
# Required: No (Future Stage)
# Optional: No
# Example: dev_secret_key_change_in_production
SECRET_KEY=dev_secret_key_change_in_production

# JWT_SECRET
# What: Secret key for signing JSON Web Tokens.
# Required: No (Future Stage)
# Optional: No
# Example: dev_jwt_secret_change_in_production
JWT_SECRET=dev_jwt_secret_change_in_production

# =================================================
# [FUTURE] Vector Storage (Qdrant)
# =================================================

# QDRANT_HOST
# What: Hostname for the Qdrant vector database.
# Required: No (Future Stage)
# Optional: Yes
# Example: localhost
QDRANT_HOST=localhost

# QDRANT_PORT
# What: Port for the Qdrant vector database.
# Required: No (Future Stage)
# Optional: Yes
# Example: 6333
QDRANT_PORT=6333

# =================================================
# [FUTURE] Graph Storage (Neo4j)
# =================================================

# NEO4J_URI
# What: Bolt URI for the Neo4j graph database.
# Required: No (Future Stage)
# Optional: Yes
# Example: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687

# NEO4J_USER
# What: Username for the Neo4j database.
# Required: No (Future Stage)
# Optional: Yes
# Example: neo4j
NEO4J_USER=neo4j

# NEO4J_PASSWORD
# What: Password for the Neo4j database.
# Required: No (Future Stage)
# Optional: Yes
# Example: neo4j_dev_password
NEO4J_PASSWORD=neo4j_dev_password

# =================================================
# [FUTURE] Object Storage (MinIO/S3)
# =================================================

# MINIO_ENDPOINT
# What: Endpoint for the MinIO object storage server.
# Required: No (Future Stage)
# Optional: Yes
# Example: localhost:9000
MINIO_ENDPOINT=localhost:9000

# MINIO_ACCESS_KEY
# What: Access key for MinIO.
# Required: No (Future Stage)
# Optional: Yes
# Example: minioadmin
MINIO_ACCESS_KEY=minioadmin

# MINIO_SECRET_KEY
# What: Secret key for MinIO.
# Required: No (Future Stage)
# Optional: Yes
# Example: minioadmin
MINIO_SECRET_KEY=minioadmin
